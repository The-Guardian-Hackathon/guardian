# Flight recovery backend (Person A's half) — copy to .env and fill in as keys arrive
PORT=4000
MOCK=1
# LIVE_CALLS=1 makes the two call moments (negotiate, confirm) place REAL outbound calls
# to DEMO_PHONE via Vocal Bridge. 0 = simulated calls, nothing rings.
LIVE_CALLS=0

# Vocal Bridge — outbound voice calls (server-only secret, never ship to a browser)
VOCAL_BRIDGE_API_KEY=
VOCAL_BRIDGE_AGENT_ID=

# Sabre — flight lookup / rebooking search
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_ENV=cert

# PayPal — SANDBOX ONLY, never live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# Test phone the agent calls (a teammate role-playing the airline rep — never a real airline)
DEMO_PHONE=
