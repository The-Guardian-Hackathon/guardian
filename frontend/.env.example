# Guardian frontend (teammate's half) — copy to .env.local
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# 1 = run on the built-in fixture demo (no backend needed). Set to 0 once the backend is live.
NEXT_PUBLIC_USE_FIXTURES=1

# LandingAI ADE — screenshot/poster extraction (call from a Next.js API route, keep the key server-side)
LANDINGAI_API_KEY=
